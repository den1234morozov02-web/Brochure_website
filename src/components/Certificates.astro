---
import { Icon } from "astro-icon/components";
import { useTranslations } from "../i18n/ui";
import { type Locale } from "../data/site";
import { certificates, membership } from "../data/certificates";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="qualifications" class="bg-ink py-20 text-cream md:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-4xl text-gold-soft md:text-5xl">{t("cert.title")}</h2>
      <p class="mt-4 text-cream/70">{t("cert.subtitle")}</p>
    </div>

    <!-- Главный сертификат: членство IMTA — всегда на виду -->
    <div
      class="mx-auto mt-10 max-w-3xl rounded-2xl bg-gold/10 p-5 ring-1 ring-gold/30 sm:p-7"
    >
      <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-center">
        <button
          type="button"
          class="cert-thumb group shrink-0 overflow-hidden rounded-lg bg-white shadow-lg ring-1 ring-gold/30 transition hover:ring-gold/60"
          data-cert-src={membership.image}
          data-cert-alt={membership.org}
          aria-label={`${t("cert.view")}: ${membership.org}`}
        >
          <img
            src={membership.image}
            alt={membership.org}
            class="h-64 w-auto object-contain transition group-hover:scale-[1.03]"
          />
        </button>
        <div class="text-center sm:text-left">
          <span
            class="inline-flex items-center gap-2 rounded-full bg-gold/15 px-3 py-1 text-xs font-medium uppercase tracking-wider text-gold-soft"
          >
            <Icon name="lucide:badge-check" class="h-4 w-4" />
            {membership.status[locale]}
          </span>
          <p class="mt-3 font-serif text-2xl text-cream">{membership.org}</p>
          <p class="mt-2 text-sm text-cream/70">{t("cert.member")}: {membership.status[locale]}</p>
          <p class="text-sm text-cream/70">No. {membership.number}</p>
          <p class="text-sm text-cream/70">{t("cert.validUntil")}: {membership.validUntil}</p>
        </div>
      </div>
    </div>

    <!-- Список квалификаций -->
    <ul class="mx-auto mt-10 grid max-w-4xl gap-x-8 gap-y-3 sm:grid-cols-2">
      {
        certificates.map((c) => (
          <li class="flex items-start gap-2 text-cream/85">
            <Icon name="lucide:award" class="mt-1 h-4 w-4 shrink-0 text-gold" />
            <span>
              {c.title[locale]}
              <span class="text-cream/45"> · {c.issuer}</span>
            </span>
          </li>
        ))
      }
    </ul>

    <!-- Кнопка-тоггл галереи (сертификаты по умолчанию скрыты) -->
    <div class="mt-10 text-center">
      <button
        id="cert-gallery-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="cert-gallery"
        class="inline-flex items-center gap-2 rounded-full border border-gold/50 px-6 py-2.5 text-gold-soft transition-colors hover:bg-gold hover:text-ink"
        data-label-show={t("cert.toggle")}
        data-label-hide={t("cert.hide")}
      >
        <Icon name="lucide:images" class="h-5 w-5" />
        <span data-toggle-label>{t("cert.toggle")}</span>
        <Icon id="cert-chevron" name="lucide:chevron-down" class="h-4 w-4 transition-transform" />
      </button>
    </div>

    <!-- Галерея сертификатов (клик — увеличение) -->
    <div id="cert-gallery" class="hidden">
      <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
        {
          certificates.map((c) => (
            <button
              type="button"
              class="cert-thumb group overflow-hidden rounded-lg bg-white/5 ring-1 ring-cream/10 transition hover:ring-gold/50"
              data-cert-src={c.image}
              data-cert-alt={c.title[locale]}
              aria-label={`${t("cert.view")}: ${c.title[locale]}`}
            >
              <img
                src={c.image}
                alt={c.title[locale]}
                loading="lazy"
                class="aspect-[3/4] w-full object-cover transition group-hover:scale-105"
              />
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Лайтбокс -->
  <div
    id="cert-lightbox"
    class="fixed inset-0 z-[60] hidden items-center justify-center bg-ink/90 p-4 backdrop-blur"
    role="dialog"
    aria-modal="true"
  >
    <button
      id="cert-close"
      class="absolute right-4 top-4 rounded-full bg-cream/10 p-2 text-cream hover:bg-cream/20"
      aria-label="Close"
    >
      <Icon name="lucide:x" class="h-6 w-6" />
    </button>
    <img id="cert-full" src="" alt="" class="max-h-[90vh] max-w-full rounded-lg object-contain shadow-2xl" />
  </div>
</section>

<script>
  // --- Сворачиваемая галерея (по умолчанию скрыта) ---
  const galToggle = document.getElementById("cert-gallery-toggle");
  const gallery = document.getElementById("cert-gallery");
  const chevron = document.getElementById("cert-chevron");
  const galLabel = galToggle?.querySelector<HTMLElement>("[data-toggle-label]");

  function setGallery(show: boolean) {
    if (!gallery || !galToggle) return;
    gallery.classList.toggle("hidden", !show);
    galToggle.setAttribute("aria-expanded", String(show));
    chevron?.classList.toggle("rotate-180", show);
    if (galLabel) {
      galLabel.textContent = show
        ? galToggle.dataset.labelHide ?? ""
        : galToggle.dataset.labelShow ?? "";
    }
  }

  galToggle?.addEventListener("click", () =>
    setGallery(gallery?.classList.contains("hidden") ?? false)
  );

  // Открытие галереи кликом по пункту "Qualifications" в навбаре
  document.querySelectorAll('a[href$="#qualifications"]').forEach((link) => {
    link.addEventListener("click", () => setGallery(true));
  });

  // --- Лайтбокс ---
  const box = document.getElementById("cert-lightbox");
  const full = document.getElementById("cert-full") as HTMLImageElement | null;
  const close = document.getElementById("cert-close");

  function open(src: string, alt: string) {
    if (!box || !full) return;
    full.src = src;
    full.alt = alt;
    box.classList.remove("hidden");
    box.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function hide() {
    if (!box) return;
    box.classList.add("hidden");
    box.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLButtonElement>(".cert-thumb").forEach((btn) => {
    btn.addEventListener("click", () =>
      open(btn.dataset.certSrc ?? "", btn.dataset.certAlt ?? "")
    );
  });
  close?.addEventListener("click", hide);
  box?.addEventListener("click", (e) => {
    if (e.target === box) hide();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") hide();
  });
</script>
